<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network for weather API -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Broadcast permission for MCU head unit event service -->
    <uses-permission android:name="com.szchoiceway.permission.broadcast" />

    <!-- GPS for telemetry and weather location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Required for LocationManager.sendExtraCommand (A-GPS reset) — normal protection, auto-granted -->
    <uses-permission android:name="android.permission.ACCESS_LOCATION_EXTRA_COMMANDS" />

    <!-- Compass / sensors -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- Wallpaper from gallery -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- A launcher must enumerate non-launcher and vendor system apps so users can
         assign buried head-unit components to widgets and shortcuts. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Required on API 30+ so PackageManager returns launcher apps explicitly. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <!-- Public package-visibility evidence and safe launch candidates. -->
        <package android:name="com.android.settings" />
        <package android:name="com.dofun.variety" />
        <package android:name="com.dofun.carsetting" />
        <package android:name="com.google.android.apps.maps" />
        <package android:name="com.navimods.radio" />
        <package android:name="com.szchoiceway.eventcenter" />
        <package android:name="com.szchoiceway.radio" />
        <package android:name="com.tw.auxin" />
        <package android:name="com.tw.bt" />
        <package android:name="com.tw.carinfoservice" />
        <package android:name="com.tw.core" />
        <package android:name="com.tw.coreservice" />
        <package android:name="com.tw.eq" />
        <package android:name="com.tw.keypad" />
        <package android:name="com.tw.service" />
        <package android:name="com.tw.twfileexplore" />
    </queries>

    <application
        android:label="Open Launcher"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:theme="@android:style/Theme.Black.NoTitleBar"
        android:exported="true">

        <!-- Single launcher activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustNothing">

            <!-- HOME launcher intent filters -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Notification listener service for MediaSession / Now Playing -->
        <service
            android:name=".service.MediaListenerService"
            android:exported="true"
            android:label="Open Launcher Media"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>

</manifest>
